# ---------------------------------------------------------------- utilities

def ensure_home():
    os.makedirs(TICKY_HOME, exist_ok=True)
    os.makedirs(BIN_DIR, exist_ok=True)


def now_iso():
    return datetime.now(timezone.utc).isoformat(timespec="seconds")


def load_config():
    try:
        with open(CONFIG_PATH) as f:
            return json.load(f)
    except FileNotFoundError:
        return None


def save_config(cfg):
    ensure_home()
    tmp = CONFIG_PATH + ".tmp"
    with open(tmp, "w") as f:
        json.dump(cfg, f, indent=2)
        f.write("\n")
    os.replace(tmp, CONFIG_PATH)


def require_config():
    cfg = load_config()
    if cfg is None:
        die("no config found; run `ticky init` first")
    return cfg


def get_agent(cfg, name):
    for a in cfg["agents"]:
        if a["name"] == name.lower():
            return a
    return None


def die(msg, code=1):
    print(f"ticky: {msg}", file=sys.stderr)
    sys.exit(code)


def load_env_file():
    """API keys etc. from ~/.ticky/env, KEY=value per line."""
    env = {}
    try:
        with open(ENV_PATH) as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue
                k, v = line.split("=", 1)
                env[k.strip()] = v.strip()
    except FileNotFoundError:
        pass
    return env


def child_env():
    """Environment for backend subprocesses: inherit, overlay ~/.ticky/env,
    drop vars that mark this process as nested inside a Claude Code session."""
    env = dict(os.environ)
    for k in list(env):
        if k == "CLAUDECODE" or k.startswith("CLAUDE_CODE_"):
            env.pop(k)
    env.update(load_env_file())
    return env


def append_log(entry):
    ensure_home()
    with open(LOG_PATH, "a") as f:
        f.write(json.dumps(entry) + "\n")


def read_log_tail(n=20):
    try:
        with open(LOG_PATH, "rb") as f:
            f.seek(0, 2)
            size = f.tell()
            f.seek(max(0, size - 65536))
            lines = f.read().decode("utf-8", "replace").strip().splitlines()
    except FileNotFoundError:
        return []
    out = []
    for line in lines[-n:]:
        try:
            out.append(json.loads(line))
        except json.JSONDecodeError:
            pass
    return out


_state_lock = threading.Lock()


def _pid_alive(pid):
    try:
        os.kill(int(pid), 0)
        return True
    except (OSError, TypeError, ValueError):
        return False


def write_state(running, owner=None):
    """Publish one process's calls without erasing calls from other MCP sessions."""
    ensure_home()
    owner = owner or f"process-{os.getpid()}"
    with _state_lock:
        with open(STATE_LOCK_PATH, "a+") as lock_file:
            if fcntl is not None:
                fcntl.flock(lock_file.fileno(), fcntl.LOCK_EX)
            try:
                try:
                    with open(STATE_PATH) as f:
                        state = json.load(f)
                except (FileNotFoundError, json.JSONDecodeError, OSError):
                    state = {}

                owners = state.get("owners") if isinstance(state.get("owners"), dict) else {}
                owners = {
                    key: value for key, value in owners.items()
                    if isinstance(value, dict) and _pid_alive(value.get("pid"))
                }
                if running:
                    owners[owner] = {"pid": os.getpid(), "running": running}
                else:
                    owners.pop(owner, None)

                combined = []
                for value in owners.values():
                    calls = value.get("running")
                    if isinstance(calls, list):
                        combined.extend(calls)

                tmp = STATE_PATH + ".tmp"
                with open(tmp, "w") as f:
                    json.dump({"running": combined, "owners": owners, "updated": now_iso()}, f)
                os.replace(tmp, STATE_PATH)
            finally:
                if fcntl is not None:
                    fcntl.flock(lock_file.fileno(), fcntl.LOCK_UN)


# ------------------------------------------------------------ backend calls

def build_prompt(agent, task, context):
    parts = [
        f"You are {agent['display']}, a subagent dispatched by a boss LLM via ticky.",
        f"Specialty: {agent['specialty']}",
        "Complete the task and reply with the result only; the boss reads your last message.",
        "",
        f"TASK: {task}",
    ]
    if context:
        parts += ["", f"CONTEXT FROM BOSS: {context}"]
    return "\n".join(parts)


def codex_cmd(agent, prompt, out_file):
    access = {"read-only": "read-only", "workspace-write": "workspace-write", "full": "danger-full-access"}[agent["access"]]
    cmd = [
        "codex", "exec",
        "--skip-git-repo-check",
        "-s", access,
        "-C", os.path.expanduser(agent.get("workdir") or "~"),
        "-o", out_file,
    ]
    if agent.get("network") and agent["access"] == "workspace-write":
        cmd += ["-c", "sandbox_workspace_write.network_access=true"]
    if agent.get("model"):
        cmd += ["-m", agent["model"]]
    cmd += agent.get("extra_args", [])
    cmd.append(prompt)
    return cmd


def claude_cmd(agent, prompt):
    cmd = ["claude", "-p", prompt, "--output-format", "text"]
    access = agent["access"]
    if access == "read-only":
        cmd += ["--allowedTools", "Read Glob Grep WebFetch WebSearch TodoWrite",
                "--disallowedTools", "Bash Edit Write NotebookEdit"]
    elif access == "workspace-write":
        # No OS sandbox here: Bash stays blocked so "workspace-write" means file
        # edits via Edit/Write only. Use access=full for Bash.
        cmd += ["--permission-mode", "acceptEdits",
                "--allowedTools", "Read Glob Grep WebFetch WebSearch TodoWrite Edit Write NotebookEdit",
                "--disallowedTools", "Bash"]
    else:
        cmd += ["--dangerously-skip-permissions"]
    if agent.get("model"):
        cmd += ["--model", agent["model"]]
    cmd += agent.get("extra_args", [])
    return cmd


def run_agent(agent, task, context=None):
    """Run one backend call. Returns (ok, text, duration_seconds)."""
    prompt = build_prompt(agent, task, context)
    timeout = int(agent.get("timeout") or 900)
    start = time.monotonic()

    if agent["backend"] == "mock":
        return True, f"[mock:{agent['name']}] task received: {task}", 0.0

    out_file = None
    if agent["backend"] == "codex":
        fd, out_file = tempfile.mkstemp(prefix="ticky-", suffix=".md")
        os.close(fd)
        cmd = codex_cmd(agent, prompt, out_file)
    elif agent["backend"] == "claude":
        cmd = claude_cmd(agent, prompt)
    else:
        return False, f"unknown backend {agent['backend']!r}", 0.0

    try:
        proc = subprocess.Popen(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            stdin=subprocess.DEVNULL,
            cwd=os.path.expanduser(agent.get("workdir") or "~"),
            env=child_env(),
            text=True,
            start_new_session=True,
        )
    except OSError as error:
        if out_file:
            with contextlib.suppress(OSError):
                os.unlink(out_file)
        return False, f"could not start backend {cmd[0]!r}: {error}", 0.0

    try:
        stdout, stderr = proc.communicate(timeout=timeout)
    except subprocess.TimeoutExpired:
        if hasattr(os, "killpg"):  # POSIX: kill the whole process group
            try:
                os.killpg(proc.pid, signal.SIGKILL)
            except ProcessLookupError:
                pass
        else:
            proc.kill()
        proc.wait()
        return False, f"timed out after {timeout}s", time.monotonic() - start

    duration = time.monotonic() - start
    text = ""
    if out_file:
        try:
            with open(out_file) as f:
                text = f.read().strip()
        finally:
            try:
                os.unlink(out_file)
            except OSError:
                pass
    if not text:
        text = (stdout or "").strip()

    if proc.returncode != 0:
        err = (stderr or "").strip()
        detail = text or err or "no output"
        return False, f"backend exited {proc.returncode}: {detail[-2000:]}", duration
    if not text:
        return False, "backend produced no output", duration
    return True, text, duration


# ------------------------------------------------------------- MCP server

def tool_name(agent):
    return f"ask_{agent['name']}"


def tool_def(agent):
    model = f"/{agent['model']}" if agent.get("model") else ""
    desc = (
        f"{agent['display']} ({agent['backend']}{model} subagent). {agent['specialty']} "
        f"{agent.get('routing_note', '')} Priority {agent['priority']} (lower = prefer first). "
        f"Access: {agent['access']}, workdir: {agent.get('workdir', '~')}. "
        f"Runs synchronously and returns the agent's final answer."
    )
    return {
        "name": tool_name(agent),
        "description": desc,
        "annotations": {"readOnlyHint": agent["access"] == "read-only"},
        "inputSchema": {
            "type": "object",
            "properties": {
                "task": {
                    "type": "string",
                    "description": "The complete, self-contained task. The subagent has no other context.",
                },
                "reason": {
                    "type": "string",
                    "description": "One line: why this agent for this task. Logged and shown in the ticky widget.",
                },
                "context": {
                    "type": "string",
                    "description": "Optional extra context: file paths, constraints, prior findings.",
                },
            },
            "required": ["task", "reason"],
        },
    }


def roster_tool_def():
    return {
        "name": "ticky_roster",
        "description": (
            "List the available ticky subagents with their specialties, priorities, "
            "access levels, and recent usage. Call this when unsure which agent fits."
        ),
        "annotations": {"readOnlyHint": True},
        "inputSchema": {"type": "object", "properties": {}},
    }


def roster_text(cfg):
    lines = [f"ticky roster ({len([a for a in cfg['agents'] if a.get('enabled', True)])} agents). "
             f"Global preferences: {cfg.get('preferences', '(none)')}", ""]
    for a in sorted(cfg["agents"], key=lambda a: a["priority"]):
        if not a.get("enabled", True):
            continue
        model = f"/{a['model']}" if a.get("model") else ""
        lines.append(
            f"- {a['display']} (tool {tool_name(a)}, {a['backend']}{model}, priority {a['priority']}, "
            f"access {a['access']}, workdir {a.get('workdir', '~')}): {a['specialty']} {a.get('routing_note', '')}"
        )
    recent = read_log_tail(5)
    if recent:
        lines += ["", "Recent calls:"]
        for e in recent:
            lines.append(f"- {e.get('ts')} {e.get('agent')} [{e.get('status')}] {e.get('reason', '')}")
    return "\n".join(lines)


class McpServer:
    def __init__(self, cfg):
        self.cfg = cfg
        self.out_lock = threading.Lock()
        self.running = {}  # id -> {agent, reason, started}
        self.run_lock = threading.Lock()
        self.workers = []
        self.boss = "unknown"
        self.state_owner = f"serve-{os.getpid()}"

    def dbg(self, direction, text):
        # wire tracing, enabled by `touch ~/.ticky/debug`
        if not os.path.exists(os.path.join(TICKY_HOME, "debug")):
            return
        try:
            with open(os.path.join(TICKY_HOME, "server-debug.log"), "a") as f:
                f.write(f"{now_iso()} {direction} {text}\n")
        except OSError:
            pass

    def send(self, msg):
        with self.out_lock:
            out = json.dumps(msg)
            self.dbg(">>", out)
            sys.stdout.write(out + "\n")
            sys.stdout.flush()

    def reply(self, req_id, result):
        self.send({"jsonrpc": "2.0", "id": req_id, "result": result})

    def reply_err(self, req_id, code, message):
        self.send({"jsonrpc": "2.0", "id": req_id, "error": {"code": code, "message": message}})

    def publish_state(self):
        with self.run_lock:
            running = list(self.running.values())
        write_state(running, self.state_owner)

    def handle_call(self, req_id, params):
        name = params.get("name", "")
        args = params.get("arguments") or {}
        if name == "ticky_roster":
            self.reply(req_id, {"content": [{"type": "text", "text": roster_text(self.cfg)}], "isError": False})
            return

        agent = None
        for a in self.cfg["agents"]:
            if tool_name(a) == name and a.get("enabled", True):
                agent = a
                break
        if agent is None:
            self.reply_err(req_id, -32602, f"unknown tool {name!r}")
            return

        task = args.get("task") or ""
        reason = args.get("reason") or "(no reason given)"
        context = args.get("context")
        if not task.strip():
            self.reply(req_id, {"content": [{"type": "text", "text": "error: empty task"}], "isError": True})
            return

        key = f"{req_id}-{time.time()}"
        with self.run_lock:
            self.running[key] = {"agent": agent["display"], "reason": reason, "started": now_iso()}
        self.publish_state()

        try:
            ok, text, duration = run_agent(agent, task, context)
        except Exception as error:
            ok, text, duration = False, f"backend failed unexpectedly: {error}", 0.0
        finally:
            with self.run_lock:
                self.running.pop(key, None)
            self.publish_state()

        append_log({
            "ts": now_iso(),
            "boss": self.boss,
            "agent": agent["display"],
            "backend": agent["backend"],
            "reason": reason,
            "task_preview": task[:200],
            "status": "ok" if ok else "error",
            "duration_s": round(duration, 1),
            "chars": len(text),
        })
        self.reply(req_id, {"content": [{"type": "text", "text": text}], "isError": not ok})

    def handle(self, msg):
        method = msg.get("method")
        req_id = msg.get("id")
        params = msg.get("params") or {}

        if method == "initialize":
            client = params.get("clientInfo") or {}
            self.boss = client.get("name", "unknown")
            proto = params.get("protocolVersion") or PROTOCOL_FALLBACK
            enabled = [a for a in self.cfg["agents"] if a.get("enabled", True)]
            names = ", ".join(f"{a['display']} ({tool_name(a)})" for a in sorted(enabled, key=lambda a: a["priority"]))
            self.reply(req_id, {
                "protocolVersion": proto,
                "capabilities": {"tools": {"listChanged": False}},
                "serverInfo": {"name": "ticky", "version": VERSION},
                "instructions": (
                    f"ticky gives you named subagents: {names}. "
                    f"Routing preferences: {self.cfg.get('preferences', '(none)')} "
                    "Every call needs a one-line `reason`; it is logged and shown to the user "
                    "in the ticky widget. Tasks must be self-contained; subagents share no context with you."
                ),
            })
        elif method == "notifications/initialized":
            pass
        elif method == "ping":
            self.reply(req_id, {})
        elif method == "tools/list":
            tools = [tool_def(a) for a in sorted(self.cfg["agents"], key=lambda a: a["priority"])
                     if a.get("enabled", True)]
            tools.append(roster_tool_def())
            self.reply(req_id, {"tools": tools})
        elif method == "tools/call":
            t = threading.Thread(target=self.handle_call, args=(req_id, params), daemon=True)
            self.workers.append(t)
            t.start()
        elif req_id is not None:
            self.reply_err(req_id, -32601, f"method {method!r} not supported")
        # notifications for unsupported methods are silently ignored

    def serve(self):
        write_state([], self.state_owner)
        for line in sys.stdin:
            line = line.strip()
            if not line:
                continue
            self.dbg("<<", line)
            try:
                msg = json.loads(line)
            except json.JSONDecodeError:
                continue
            if isinstance(msg, list):  # JSON-RPC batch
                for m in msg:
                    try:
                        self.handle(m)
                    except Exception as e:
                        if isinstance(m, dict) and m.get("id") is not None:
                            self.reply_err(m["id"], -32603, f"internal error: {e}")
                continue
            try:
                self.handle(msg)
            except Exception as e:  # keep the server alive no matter what
                if msg.get("id") is not None:
                    self.reply_err(msg["id"], -32603, f"internal error: {e}")
        for t in self.workers:  # stdin closed: finish in-flight calls before exiting
            t.join()
        write_state([], self.state_owner)


def cmd_serve(_args):
    cfg = require_config()
    McpServer(cfg).serve()


# ----------------------------------------------------------- auth detection

def detect_backends():
    """Returns {backend: {installed, auth, detail}}."""
    envs = child_env()
    out = {}

    claude_path = shutil.which("claude")
    auth = False
    detail = "not installed"
    if claude_path:
        detail = "installed, auth not detected"
        if envs.get("ANTHROPIC_API_KEY"):
            auth, detail = True, "API key (ANTHROPIC_API_KEY)"
        elif os.path.exists(os.path.expanduser("~/.claude/.credentials.json")):
            auth, detail = True, "subscription login"
        elif IS_MAC:  # credentials can also live in the macOS Keychain
            r = subprocess.run(
                ["security", "find-generic-password", "-s", "Claude Code-credentials"],
                capture_output=True,
            )
            if r.returncode == 0:
                auth, detail = True, "subscription login (Keychain)"
    out["claude"] = {"installed": bool(claude_path), "auth": auth, "detail": detail}

    codex_path = shutil.which("codex")
    auth = False
    detail = "not installed"
    if codex_path:
        detail = "installed, auth not detected"
        if envs.get("OPENAI_API_KEY"):
            auth, detail = True, "API key (OPENAI_API_KEY)"
        elif os.path.exists(os.path.expanduser("~/.codex/auth.json")):
            auth, detail = True, "subscription login (ChatGPT)"
    out["codex"] = {"installed": bool(codex_path), "auth": auth, "detail": detail}
    return out


# -------------------------------------------------------------- widget mgmt
# Everything below this banner is the macOS frontend (Swift menu bar app,
# launchd). Ports live in widget/<platform>/ and get their own branch here.

def widget_build():
    if not IS_MAC:
        die(WIDGET_UNSUPPORTED_MSG)
    ensure_home()
    if not os.path.exists(WIDGET_SRC):
        die(f"widget source not found at {WIDGET_SRC}")
    r = subprocess.run(["swiftc", "-O", WIDGET_SRC, "-o", WIDGET_BIN], capture_output=True, text=True)
    if r.returncode != 0:
        die(f"widget build failed:\n{r.stderr}")
    print(f"built {WIDGET_BIN}")


WIDGET_LABEL = "fun.ticky.widget"


def widget_pids():
    if not IS_MAC:
        return []
    # pgrep finds candidate processes by executable name. Then filter by the
    # exact installed binary so alternate TICKY_HOME test runs do not see or
    # stop the user's live widget.
    r = subprocess.run(["pgrep", "-x", "ticky-widget"], capture_output=True, text=True)
    if r.returncode != 0:
        return []
    matches = []
    for raw_pid in r.stdout.split():
        pid = int(raw_pid)
        proc = subprocess.run(["ps", "-p", str(pid), "-o", "command="],
                              capture_output=True, text=True)
        command = proc.stdout.strip()
        if command == WIDGET_BIN or command.startswith(WIDGET_BIN + " "):
            matches.append(pid)
    return matches


def widget_start():
    if not os.path.exists(WIDGET_BIN):
        widget_build()
    if widget_pids():
        print("widget already running")
        return
    # Prefer launchd ownership: a raw child process dies with whatever shell
    # session spawned it, a bootstrapped service does not.
    if os.path.exists(LAUNCH_AGENT):
        domain = f"gui/{os.getuid()}"
        subprocess.run(["launchctl", "bootstrap", domain, LAUNCH_AGENT],
                       capture_output=True)  # errors if already loaded; fine
        subprocess.run(["launchctl", "kickstart", f"{domain}/{WIDGET_LABEL}"],
                       capture_output=True)
        time.sleep(0.8)
        if widget_pids():
            print("widget running (menu bar, launchd-managed)")
            return
    subprocess.Popen([WIDGET_BIN], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                     stdin=subprocess.DEVNULL, start_new_session=True)
    time.sleep(0.8)
    if widget_pids():
        print("widget running (menu bar)")
    else:
        die("widget failed to stay up; try running it directly: " + WIDGET_BIN)


def widget_stop():
    was_running = bool(widget_pids())
    subprocess.run(["launchctl", "bootout", f"gui/{os.getuid()}/{WIDGET_LABEL}"],
                   capture_output=True)  # unloads if launchd-managed; else no-op
    for p in widget_pids():
        try:
            os.kill(p, signal.SIGTERM)
        except ProcessLookupError:
            pass
    print("widget stopped" if was_running else "widget not running")


def widget_login_enable():
    os.makedirs(os.path.dirname(LAUNCH_AGENT), exist_ok=True)
    plist = f"""<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>{WIDGET_LABEL}</string>
  <key>ProgramArguments</key><array><string>{WIDGET_BIN}</string></array>
  <key>RunAtLoad</key><true/>
</dict>
</plist>
"""
    with open(LAUNCH_AGENT, "w") as f:
        f.write(plist)
    print(f"login item written: {LAUNCH_AGENT}")


def cmd_setup(_args):
    """Open the native setup window (backends, agents, models, preferences)."""
    if not IS_MAC:
        die(WIDGET_UNSUPPORTED_MSG + " Edit ~/.ticky/config.json directly, or use "
            "`ticky add` / `ticky edit` / `ticky prefs`.")
    ensure_home()
    widget_start()
    # the widget polls for this flag once a second and opens the setup window
    with open(os.path.join(TICKY_HOME, "open-setup"), "w"):
        pass
    print("setup window opening (ticky widget)")


def cmd_widget(args):
    if not IS_MAC:
        if (args.action or "start") == "status":
            print("widget: unavailable on this platform")
            return
        die(WIDGET_UNSUPPORTED_MSG)
    action = args.action or "start"
    if action == "build":
        widget_build()
    elif action == "start":
        widget_start()
    elif action == "stop":
        widget_stop()
    elif action == "restart":
        widget_stop()
        time.sleep(0.5)
        widget_start()
    elif action == "login":
        widget_login_enable()
    elif action == "status":
        pids = widget_pids()
        print(f"widget: {'running (pid ' + str(pids[0]) + ')' if pids else 'not running'}")


