def cmd_status(_args):
    cfg = load_config()
    backends = detect_backends()
    print(f"ticky {VERSION}  home={TICKY_HOME}")
    for b in ("codex", "claude"):
        info = backends[b]
        mark = "ok" if info["auth"] else ("found" if info["installed"] else "missing")
        print(f"  {b:7s} [{mark}] {info['detail']}")
    pids = widget_pids()
    print(f"  widget  [{'ok' if pids else 'off'}] {'pid ' + str(pids[0]) if pids else 'not running'}")
    if cfg is None:
        print("  config  [missing] run `ticky init`")
        return
    print(f"  prefs   {cfg.get('preferences', '(none)')[:100]}")
    print("  agents:")
    for a in sorted(cfg["agents"], key=lambda a: a["priority"]):
        state = "on " if a.get("enabled", True) else "off"
        model = f"/{a['model']}" if a.get("model") else ""
        print(f"    [{state}] {a['display']:8s} p{a['priority']} {a['backend']}{model:12s} "
              f"{a['access']:15s} wd={a.get('workdir', '~')}  {a['specialty']}")
    entries = read_log_tail(200)
    today = datetime.now().astimezone().date()
    n_today = 0
    for e in entries:
        try:
            if datetime.fromisoformat(e.get("ts", "")).astimezone().date() == today:
                n_today += 1
        except ValueError:
            pass
    print(f"  calls   {len(entries)} recent logged, ~{n_today} today (ticky log for detail)")


def fmt_entry(e):
    mark = {"ok": "+", "error": "!"}.get(e.get("status"), "?")
    return (f"[{mark}] {e.get('ts', '')}  {e.get('agent', '?'):8s} <- {e.get('boss', '?')} "
            f"({e.get('duration_s', '?')}s)  {e.get('reason', '')}")


def cmd_log(args):
    if args.follow:
        try:
            with open(LOG_PATH) as f:
                f.seek(0, 2)
                while True:
                    line = f.readline()
                    if line:
                        try:
                            print(fmt_entry(json.loads(line)))
                        except json.JSONDecodeError:
                            pass
                    else:
                        time.sleep(0.5)
        except FileNotFoundError:
            die("no log yet")
        except KeyboardInterrupt:
            return
    else:
        for e in read_log_tail(args.n):
            print(fmt_entry(e))


def cmd_call(args):
    cfg = require_config()
    a = get_agent(cfg, args.agent)
    if not a:
        die(f"no agent named {args.agent!r}; agents: {', '.join(x['name'] for x in cfg['agents'])}")
    reason = args.reason or "manual ticky call"
    owner = f"manual-{os.getpid()}"
    write_state([{"agent": a["display"], "reason": reason, "started": now_iso()}], owner)
    try:
        ok, text, duration = run_agent(a, args.task, args.context)
    except Exception as error:
        ok, text, duration = False, f"backend failed unexpectedly: {error}", 0.0
    finally:
        write_state([], owner)
    append_log({
        "ts": now_iso(), "boss": "terminal", "agent": a["display"], "backend": a["backend"],
        "reason": reason, "task_preview": args.task[:200],
        "status": "ok" if ok else "error", "duration_s": round(duration, 1), "chars": len(text),
    })
    print(text)
    sys.exit(0 if ok else 1)


def cmd_doctor(_args):
    """End-to-end smoke test of the MCP pipeline using a throwaway mock agent."""
    cfg = require_config()
    probe = {
        "name": "_probe", "display": "_probe", "backend": "mock", "model": None,
        "specialty": "doctor probe", "routing_note": "", "priority": 99,
        "access": "read-only", "workdir": "~", "network": False, "timeout": 30,
        "enabled": True, "extra_args": [],
    }
    test_cfg = {"version": 1, "preferences": cfg.get("preferences", ""), "agents": cfg["agents"] + [probe]}

    msgs = [
        {"jsonrpc": "2.0", "id": 1, "method": "initialize",
         "params": {"protocolVersion": PROTOCOL_FALLBACK, "clientInfo": {"name": "ticky-doctor"}, "capabilities": {}}},
        {"jsonrpc": "2.0", "method": "notifications/initialized"},
        {"jsonrpc": "2.0", "id": 2, "method": "tools/list"},
        {"jsonrpc": "2.0", "id": 3, "method": "tools/call",
         "params": {"name": "ask__probe", "arguments": {"task": "ping", "reason": "doctor self-test"}}},
    ]
    with tempfile.NamedTemporaryFile("w", suffix=".json", delete=False) as tf:
        json.dump(test_cfg, tf)
        tmp_cfg = tf.name
    env = dict(os.environ)
    inp = "\n".join(json.dumps(m) for m in msgs) + "\n"
    r = subprocess.run(
        [sys.executable, self_path(), "serve", "--config-override", tmp_cfg],
        input=inp, capture_output=True, text=True, timeout=60, env=env)
    os.unlink(tmp_cfg)

    ok_init = ok_tools = ok_call = False
    n_tools = 0
    for line in r.stdout.splitlines():
        try:
            m = json.loads(line)
        except json.JSONDecodeError:
            continue
        if m.get("id") == 1 and "result" in m:
            ok_init = True
        if m.get("id") == 2 and "result" in m:
            n_tools = len(m["result"].get("tools", []))
            ok_tools = n_tools > 0
        if m.get("id") == 3 and "result" in m and not m["result"].get("isError"):
            ok_call = True

    print(f"  MCP handshake     {'ok' if ok_init else 'FAIL'}")
    print(f"  tools/list        {'ok, ' + str(n_tools) + ' tools' if ok_tools else 'FAIL'}")
    print(f"  tools/call (mock) {'ok' if ok_call else 'FAIL'}")
    backends = detect_backends()
    for b in ("codex", "claude"):
        info = backends[b]
        mark = "ok" if info["auth"] else ("found, no auth?" if info["installed"] else "MISSING")
        print(f"  backend {b:7s}   {mark}")
    sys.exit(0 if (ok_init and ok_tools and ok_call) else 1)


# ---------------------------------------------------------------- argparse

def main():
    global CONFIG_PATH
    ap = argparse.ArgumentParser(prog="ticky", description=__doc__.splitlines()[0])
    ap.add_argument("--version", action="version", version=f"ticky {VERSION}")
    sub = ap.add_subparsers(dest="cmd")

    p = sub.add_parser("init", help="one-command setup: config, boss registration, widget")
    p.add_argument("--yes", "-y", action="store_true", help="non-interactive, keep/create defaults")
    p.add_argument("--no-install", action="store_true", help="skip registering with claude/codex")
    p.add_argument("--no-widget", action="store_true", help="skip building/starting the widget")
    p.set_defaults(fn=cmd_init)

    p = sub.add_parser("serve", help="run the MCP stdio server (bosses call this)")
    p.add_argument("--config-override", help=argparse.SUPPRESS)
    p.set_defaults(fn=cmd_serve)

    p = sub.add_parser("status", help="show backends, auth, roster, widget")
    p.set_defaults(fn=cmd_status)

    p = sub.add_parser("setup", help="open the native setup window")
    p.set_defaults(fn=cmd_setup)

    p = sub.add_parser("add", help="add a custom agent (interactive without flags)")
    p.add_argument("--name")
    p.add_argument("--backend", choices=BACKENDS)
    p.add_argument("--model")
    p.add_argument("--specialty")
    p.add_argument("--note", help="routing note the boss sees")
    p.add_argument("--priority", type=int, default=2)
    p.add_argument("--access", choices=ACCESS_LEVELS)
    p.add_argument("--workdir")
    p.add_argument("--timeout", type=int, default=900)
    p.set_defaults(fn=cmd_add)

    p = sub.add_parser("remove", help="remove an agent")
    p.add_argument("name")
    p.set_defaults(fn=cmd_remove)

    p = sub.add_parser("edit", help="edit agent fields: ticky edit finch access=full priority=1")
    p.add_argument("name")
    p.add_argument("set", nargs="+", metavar="key=value")
    p.set_defaults(fn=cmd_edit)

    p = sub.add_parser("prefs", help="show or set global routing preferences")
    p.add_argument("text", nargs="*", help="new preferences text (blank = show)")
    p.set_defaults(fn=cmd_prefs)

    p = sub.add_parser("key", help="store API keys for backends (0600 env file)")
    p.add_argument("action", choices=["set", "list", "unset"])
    p.add_argument("name", nargs="?")
    p.set_defaults(fn=cmd_key)

    p = sub.add_parser("install", help="register the MCP server with boss CLIs")
    p.add_argument("target", nargs="?", choices=["claude", "codex", "all"], default="all")
    p.set_defaults(fn=cmd_install)

    p = sub.add_parser("uninstall", help="remove the MCP server from boss CLIs")
    p.add_argument("target", nargs="?", choices=["claude", "codex", "all"], default="all")
    p.set_defaults(fn=cmd_uninstall)

    p = sub.add_parser("log", help="show the call log")
    p.add_argument("-n", type=int, default=20, help="entries to show")
    p.add_argument("-f", "--follow", action="store_true")
    p.set_defaults(fn=cmd_log)

    p = sub.add_parser("call", help="invoke an agent from the terminal")
    p.add_argument("agent")
    p.add_argument("task")
    p.add_argument("-r", "--reason", help="reason for the log")
    p.add_argument("-c", "--context")
    p.set_defaults(fn=cmd_call)

    p = sub.add_parser("widget", help="status widget (macOS for now): start|stop|restart|build|login|status")
    p.add_argument("action", nargs="?", choices=["start", "stop", "restart", "build", "login", "status"])
    p.set_defaults(fn=cmd_widget)

    p = sub.add_parser("doctor", help="smoke-test the full MCP pipeline")
    p.set_defaults(fn=cmd_doctor)

    args = ap.parse_args()
    if getattr(args, "config_override", None):
        CONFIG_PATH = args.config_override
    if not args.cmd:
        cmd_status(args)
        return
    args.fn(args)


if __name__ == "__main__":
    main()
