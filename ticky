def cmd_add(args):
    cfg = load_config() or {"version": 1, "preferences": DEFAULT_PREFS, "agents": []}
    if args.name:
        name = args.name.lower()
        if get_agent(cfg, name):
            die(f"agent {name!r} already exists (use `ticky edit`)")
        agent = {
            "name": name,
            "display": args.name.capitalize(),
            "backend": args.backend or "codex",
            "model": args.model,
            "specialty": args.specialty or "General-purpose subagent.",
            "routing_note": args.note or "",
            "priority": args.priority,
            "access": args.access or "read-only",
            "workdir": args.workdir or "~",
            "network": False,
            "timeout": args.timeout,
            "enabled": True,
            "extra_args": [],
        }
    else:
        print("new agent (interactive; ctrl-c to abort)")
        name = prompt_str("name (short, lowercase)").lower()
        if not name:
            die("name required")
        if get_agent(cfg, name):
            die(f"agent {name!r} already exists")
        agent = {
            "name": name,
            "display": prompt_str("display name", name.capitalize()),
            "backend": prompt_choice("backend", list(BACKENDS), "codex"),
            "model": prompt_str("model (blank = backend default)") or None,
            "specialty": prompt_str("specialty (what tasks is this agent for?)"),
            "routing_note": prompt_str("routing note for the boss (optional)"),
            "priority": int(prompt_str("priority (1 = call first)", "2") or 2),
            "access": prompt_choice("access", list(ACCESS_LEVELS), "read-only"),
            "workdir": prompt_str("workdir (sandbox root)", "~"),
            "network": prompt_choice("network access (codex workspace-write only)", ["yes", "no"], "no") == "yes",
            "timeout": int(prompt_str("timeout seconds", "900") or 900),
            "enabled": True,
            "extra_args": [],
        }
    if agent["backend"] not in BACKENDS:
        die(f"backend must be one of {BACKENDS}")
    if agent["access"] not in ACCESS_LEVELS:
        die(f"access must be one of {ACCESS_LEVELS}")
    cfg["agents"].append(agent)
    save_config(cfg)
    print(f"added {agent['display']} ({agent['backend']}, {agent['access']}). "
          "Restart the boss CLI to expose the new tool.")


def cmd_remove(args):
    cfg = require_config()
    a = get_agent(cfg, args.name)
    if not a:
        die(f"no agent named {args.name!r}")
    cfg["agents"].remove(a)
    save_config(cfg)
    print(f"removed {a['display']}")


def cmd_edit(args):
    cfg = require_config()
    a = get_agent(cfg, args.name)
    if not a:
        die(f"no agent named {args.name!r}")
    ints = {"priority", "timeout"}
    bools = {"enabled", "network"}
    for pair in args.set:
        if "=" not in pair:
            die(f"expected key=value, got {pair!r}")
        k, v = pair.split("=", 1)
        if k not in a:
            die(f"unknown field {k!r}; fields: {', '.join(a.keys())}")
        if k in ints:
            a[k] = int(v)
        elif k in bools:
            a[k] = v.lower() in ("1", "true", "yes", "on")
        elif k == "access" and v not in ACCESS_LEVELS:
            die(f"access must be one of {ACCESS_LEVELS}")
        elif k == "backend" and v not in BACKENDS:
            die(f"backend must be one of {BACKENDS}")
        else:
            a[k] = v if v != "" else None
    save_config(cfg)
    print(f"updated {a['display']}: {', '.join(args.set)}")


def cmd_prefs(args):
    cfg = require_config()
    if args.text:
        cfg["preferences"] = " ".join(args.text)
        save_config(cfg)
        print("preferences updated")
    else:
        print(cfg.get("preferences", "(none)"))


def cmd_key(args):
    ensure_home()
    if args.action == "set":
        if not args.name:
            die("usage: ticky key set NAME (e.g. OPENAI_API_KEY)")
        val = getpass.getpass(f"value for {args.name} (input hidden): ").strip()
        if not val:
            die("empty value, nothing saved")
        env = load_env_file()
        env[args.name] = val
        with open(ENV_PATH, "w") as f:
            for k, v in env.items():
                f.write(f"{k}={v}\n")
        os.chmod(ENV_PATH, stat.S_IRUSR | stat.S_IWUSR)
        print(f"saved {args.name} to {ENV_PATH} (0600); backend calls will see it")
    elif args.action == "list":
        env = load_env_file()
        for k in env:
            print(k)
        if not env:
            print("(no keys stored)")
    elif args.action == "unset":
        env = load_env_file()
        if args.name in env:
            env.pop(args.name)
            with open(ENV_PATH, "w") as f:
                for k, v in env.items():
                    f.write(f"{k}={v}\n")
            os.chmod(ENV_PATH, stat.S_IRUSR | stat.S_IWUSR)
            print(f"removed {args.name}")
        else:
            print(f"{args.name} not stored")


