def self_path():
    return os.path.realpath(__file__)


def codex_set_auto_approval():
    """codex exec has no user to answer tool-approval prompts, so unapproved MCP
    calls die as 'user cancelled'. Set default_tools_approval_mode = "approve"
    for the ticky server ("auto" only clears readOnlyHint tools). Text edit
    (stdlib has no TOML writer), validated with tomllib before writing."""
    import tomllib
    path = os.path.expanduser("~/.codex/config.toml")
    try:
        with open(path) as f:
            text = f.read()
    except FileNotFoundError:
        return False
    out, in_section, done = [], False, False
    for line in text.splitlines():
        stripped = line.strip()
        if in_section and stripped.startswith("[") and stripped != "[mcp_servers.ticky]":
            in_section = False
        if in_section and stripped.startswith("default_tools_approval_mode"):
            continue  # drop any existing value; the fresh one is already inserted
        out.append(line)
        if stripped == "[mcp_servers.ticky]":
            in_section = True
            out.append('default_tools_approval_mode = "approve"')
            done = True
    if not done:
        return False
    new_text = "\n".join(out) + "\n"
    try:
        tomllib.loads(new_text)
    except tomllib.TOMLDecodeError:
        return False
    with open(path, "w") as f:
        f.write(new_text)
    return True


def cmd_install(args):
    targets = [args.target] if args.target and args.target != "all" else ["claude", "codex"]
    for t in targets:
        if t == "claude":
            if not shutil.which("claude"):
                print("claude CLI not found, skipping")
                continue
            subprocess.run(["claude", "mcp", "remove", "--scope", "user", "ticky"],
                           capture_output=True)
            r = subprocess.run(
                ["claude", "mcp", "add", "--scope", "user", "ticky", "--", self_path(), "serve"],
                capture_output=True, text=True)
            print(("claude: registered ticky (user scope)" if r.returncode == 0
                   else f"claude: register failed: {r.stderr.strip()}"))
        elif t == "codex":
            if not shutil.which("codex"):
                print("codex CLI not found, skipping")
                continue
            subprocess.run(["codex", "mcp", "remove", "ticky"], capture_output=True)
            r = subprocess.run(["codex", "mcp", "add", "ticky", "--", self_path(), "serve"],
                               capture_output=True, text=True)
            if r.returncode == 0:
                approved = codex_set_auto_approval()
                print("codex: registered ticky" +
                      (" (tools auto-approved)" if approved else
                       '; could not set auto-approval, add default_tools_approval_mode = "approve" '
                       "under [mcp_servers.ticky] in ~/.codex/config.toml"))
            else:
                print(f"codex: register failed: {r.stderr.strip()}")
        else:
            die(f"unknown install target {t!r}")


def cmd_uninstall(args):
    targets = [args.target] if args.target and args.target != "all" else ["claude", "codex"]
    for t in targets:
        if t == "claude" and shutil.which("claude"):
            subprocess.run(["claude", "mcp", "remove", "--scope", "user", "ticky"], capture_output=True)
            print("claude: removed ticky")
        elif t == "codex" and shutil.which("codex"):
            subprocess.run(["codex", "mcp", "remove", "ticky"], capture_output=True)
            print("codex: removed ticky")


def symlink_to_path():
    dest = os.path.expanduser("~/.local/bin/ticky")
    os.makedirs(os.path.dirname(dest), exist_ok=True)
    src = self_path()
    if os.path.islink(dest) or os.path.exists(dest):
        try:
            if os.path.realpath(dest) == src:
                return dest
            os.unlink(dest)
        except OSError:
            return None
    try:
        os.symlink(src, dest)
        return dest
    except OSError:
        return None


# ----------------------------------------------------------------- wizard

def prompt_str(label, default=None):
    suffix = f" [{default}]" if default is not None else ""
    val = input(f"  {label}{suffix}: ").strip()
    return val or (default if default is not None else "")


def prompt_choice(label, choices, default):
    while True:
        val = prompt_str(f"{label} ({'/'.join(choices)})", default)
        if val in choices:
            return val
        print(f"  pick one of: {', '.join(choices)}")


def cmd_init(args):
    ensure_home()
    existing = load_config()
    if existing and not args.yes:
        keep = prompt_choice("config exists; keep existing agents", ["keep", "reset"], "keep")
        if keep == "keep":
            cfg = existing
        else:
            cfg = {"version": 1, "preferences": DEFAULT_PREFS, "agents": [dict(a) for a in DEFAULT_AGENTS]}
    elif existing:
        cfg = existing
    else:
        cfg = {"version": 1, "preferences": DEFAULT_PREFS, "agents": [dict(a) for a in DEFAULT_AGENTS]}

    backends = detect_backends()
    print("ticky init")
    print("----------")
    for b in ("codex", "claude"):
        info = backends[b]
        mark = "ok" if info["auth"] else ("found" if info["installed"] else "missing")
        print(f"  {b:7s} [{mark}] {info['detail']}")

    dropped = []
    for a in list(cfg["agents"]):
        b = backends.get(a["backend"], {})
        if a["backend"] != "mock" and not b.get("installed"):
            a["enabled"] = False
            dropped.append(a["display"])
    if dropped:
        print(f"  disabled (backend missing): {', '.join(dropped)}")

    for b in ("codex", "claude"):
        info = backends[b]
        if info["installed"] and not info["auth"]:
            key = "OPENAI_API_KEY" if b == "codex" else "ANTHROPIC_API_KEY"
            login = "codex login" if b == "codex" else "claude (then /login)"
            print(f"  note: {b} has no detectable auth. Either run `{login}` or `ticky key set {key}`.")

    save_config(cfg)
    print(f"  config: {CONFIG_PATH} ({len([a for a in cfg['agents'] if a.get('enabled', True)])} agents enabled)")

    link = symlink_to_path()
    if link:
        print(f"  on PATH: {link}")

    if not args.no_install:
        cmd_install(argparse.Namespace(target="all"))
    if not args.no_widget:
        if IS_MAC:
            widget_build()
            widget_login_enable()
            widget_start()
        else:
            print(f"  note: {WIDGET_UNSUPPORTED_MSG}")

    print()
    print("done. Roster:")
    for a in sorted(cfg["agents"], key=lambda a: a["priority"]):
        state = "" if a.get("enabled", True) else " (disabled)"
        print(f"  {a['display']:8s} {a['backend']:6s} p{a['priority']} {a['access']:15s} {a['specialty']}{state}")
    print()
    print("Restart your boss CLI (claude / codex) to pick up the new MCP server.")
    print("Customize: ticky add | ticky edit <name> key=value | ticky prefs | ticky log")


